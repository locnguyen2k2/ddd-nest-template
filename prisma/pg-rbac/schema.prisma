generator client {
  provider = "prisma-client-js"
  engineType = "node"
}

datasource db {
  provider = "postgresql"
}

model User {
    id          String   @id @default(uuid(7)) @db.Uuid
    email       String   @unique
    username    String  @unique
    password    String
    first_name  String
    last_name   String
    is_deleted  Boolean  @default(false)
    status      UserStatus @default(UNVERIFIED)
    created_at   DateTime @default(now())
    updated_at   DateTime @updatedAt

    @@index([email])
    @@index([username])
}

model Permission {
    id          String   @id @default(uuid(7)) @db.Uuid
    name        String
    slug        String   @unique
    description String?
    created_at   DateTime @default(now())
    updated_at   DateTime @updatedAt

    @@index([slug])
}

model Organization {
    id          String   @id @default(uuid(7)) @db.Uuid
    name        String
    slug        String   @unique
    description String?
    created_at   DateTime @default(now())
    updated_at   DateTime @updatedAt
}

model Role {
    id          String   @id @default(uuid(7)) @db.Uuid
    name        String
    slug        String   @unique
    description String?
    created_at   DateTime @default(now())
    updated_at   DateTime @updatedAt

    @@index([slug])
}

model OrganizationRole {
    organization_id String @db.Uuid
    role_id String @db.Uuid
    created_at DateTime @default(now())
    
    @@id([organization_id, role_id])
}

model UserOrganization {
    userId String @db.Uuid
    organizationId String @db.Uuid
    roleId String? @db.Uuid
    created_at DateTime @default(now())
    
    @@id([userId, organizationId])
}

model RoleFeaturePermission {
    role_id String @db.Uuid
    feature_id String @db.Uuid
    permission_id String @db.Uuid
    created_at DateTime @default(now())
    
    @@id([role_id, feature_id, permission_id])
}

model UserRole {
    user_id String @db.Uuid
    role_id String @db.Uuid
    created_at DateTime @default(now())
    
    @@id([user_id, role_id])
}

model Feature {
    id          String   @id @default(uuid(7)) @db.Uuid
    name        String   @unique
    slug        String   @unique
    description String?
    is_enabled   Boolean  @default(true)
    created_at   DateTime @default(now())
    updated_at   DateTime @updatedAt

    @@index([slug])
    @@index([is_enabled])
}

enum UserStatus {
    ACTIVE
    INACTIVE
    UNVERIFIED
}
