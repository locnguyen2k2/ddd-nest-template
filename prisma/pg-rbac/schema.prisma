generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/@internal/rbac/client"
}

datasource db {
  provider = "postgresql"
}

model User {
    id          String   @id @default(uuid(7)) @db.Uuid
    email       String   @unique
    username    String  @unique
    password    String
    first_name  String
    last_name   String
    status      AccessControlStatus @default(ACTIVE)
    created_at   DateTime @default(now())
    updated_at   DateTime @updatedAt

    organizations UserOrganization[]
    created_permissions Permission[] @relation("PermissionCreatedBy")
    created_features Feature[] @relation("FeatureCreatedBy")
    created_roles Role[] @relation("RoleCreatedBy")
    created_user_organizations UserOrganization[] @relation("UserOrganizationCreatedBy")
    created_role_feature_permissions RoleFeaturePermission[] @relation("RoleFeaturePermissionCreatedBy")
    created_user_organization_roles UserOrganizationRole[] @relation("UserOrganizationRoleCreatedBy")
    created_organizations Organization[] @relation("OrganizationCreatedBy")
    created_projects Project[] @relation("ProjectCreatedBy")

    @@index([email])
    @@index([username])
}

model Permission {
    id          String   @id @default(uuid(7)) @db.Uuid
    name        String
    description String?
    action      PermissionAction
    created_at   DateTime @default(now())
    updated_at   DateTime @updatedAt
    created_by   String?  @db.Uuid
    updated_by   String?  @db.Uuid

    role_feature_permissions RoleFeaturePermission[]
    
    created_by_user User? @relation("PermissionCreatedBy", fields: [created_by], references: [id], onDelete: SetNull)

    @@unique([action])
    @@index([action])
}

model Organization {
    id          String   @id @default(uuid(7)) @db.Uuid
    name        String
    slug        String   @unique
    description String?
    created_at   DateTime @default(now())
    updated_at   DateTime @updatedAt
    created_by   String?  @db.Uuid
    updated_by   String?  @db.Uuid

    roles Role[]
    users UserOrganization[]
    projects Project[]
    
    created_by_user User? @relation("OrganizationCreatedBy", fields: [created_by], references: [id], onDelete: SetNull)

    @@index([slug])
}

model Project {
    id          String   @id @default(uuid(7)) @db.Uuid
    name        String
    slug        String   @unique
    description String?
    organization_id String @db.Uuid
    created_at   DateTime @default(now())
    updated_at   DateTime @updatedAt
    created_by   String?  @db.Uuid
    updated_by   String?  @db.Uuid

    features Feature[]
    
    organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
    
    created_by_user User? @relation("ProjectCreatedBy", fields: [created_by], references: [id], onDelete: SetNull)

    @@index([slug])
}

model Feature {
    id          String   @id @default(uuid(7)) @db.Uuid
    name        String   
    slug        String   
    description String?
    project_id String @db.Uuid
    status      AccessControlStatus @default(ACTIVE)
    created_at   DateTime @default(now())
    updated_at   DateTime @updatedAt
    created_by   String?  @db.Uuid
    updated_by   String?  @db.Uuid
    
    project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)

    role_feature_permissions RoleFeaturePermission[]
    
    created_by_user User? @relation("FeatureCreatedBy", fields: [created_by], references: [id], onDelete: SetNull)

    @@index([slug])
    @@index([status])
    @@unique([project_id, slug])
}

model Role {
    id          String   @id @default(uuid(7)) @db.Uuid
    name        String
    slug        String
    organization_id String @db.Uuid
    parent_role_id  String?  @db.Uuid
    description String?
    created_at   DateTime @default(now())
    updated_at   DateTime @updatedAt
    created_by   String?  @db.Uuid
    updated_by   String?  @db.Uuid
    status      AccessControlStatus @default(ACTIVE)
    
    organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
    
    role_feature_permissions RoleFeaturePermission[]
    user_organization_roles UserOrganizationRole[]
    parent_role Role? @relation("RoleHierarchy", fields: [parent_role_id], references: [id], onDelete: SetNull)
    child_roles Role[] @relation("RoleHierarchy")
    
    created_by_user User? @relation("RoleCreatedBy", fields: [created_by], references: [id], onDelete: SetNull)

    @@index([slug])
    @@unique([organization_id, slug])
}

model UserOrganization {
    organization_id String @db.Uuid
    user_id String @db.Uuid
    
    status AccessControlStatus @default(ACTIVE)
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt
    created_by String? @db.Uuid
    updated_by String? @db.Uuid
    
    user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
    organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

    user_organization_roles UserOrganizationRole[]
    
    created_by_user User? @relation("UserOrganizationCreatedBy", fields: [created_by], references: [id], onDelete: SetNull)

    @@id([user_id, organization_id])
}

model RoleFeaturePermission {
    role_id String @db.Uuid
    feature_id String @db.Uuid
    permission_id String @db.Uuid

    status AccessControlStatus @default(ACTIVE)
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt
    created_by String? @db.Uuid
    updated_by String? @db.Uuid
    
    role Role @relation(fields: [role_id], references: [id], onDelete: Cascade)
    feature Feature @relation(fields: [feature_id], references: [id], onDelete: Cascade)
    permission Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)
    
    created_by_user User? @relation("RoleFeaturePermissionCreatedBy", fields: [created_by], references: [id], onDelete: SetNull)
    
    @@id([role_id, feature_id, permission_id])
}

model UserOrganizationRole {
    role_id String @db.Uuid
    user_id String @db.Uuid
    organization_id String @db.Uuid

    status AccessControlStatus @default(ACTIVE)
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt
    created_by String? @db.Uuid
    updated_by String? @db.Uuid
    
    user_organization UserOrganization @relation(fields: [user_id, organization_id], references: [user_id, organization_id], onDelete: Cascade)
    role Role @relation(fields: [role_id], references: [id], onDelete: Cascade)
    
    created_by_user User? @relation("UserOrganizationRoleCreatedBy", fields: [created_by], references: [id], onDelete: SetNull)
    
    @@id([user_id, organization_id, role_id])
}

enum PermissionAction {
    CREATE
    READ
    UPDATE
    DELETE
}

enum AccessControlStatus {
    ACTIVE
    INACTIVE
    DELETED
}
