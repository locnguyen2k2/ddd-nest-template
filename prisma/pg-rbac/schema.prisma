generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/@internal/rbac/client"
}

datasource db {
  provider = "postgresql"
  url      = env("PG_RBAC_DATABASE_URL")
}

model User {
    id          String   @id @default(uuid(7)) @db.Uuid
    email       String   @unique
    username    String  @unique
    password    String
    first_name  String
    last_name   String
    status      AccessControlStatus @default(ACTIVE)
    created_at   DateTime @default(now())
    updated_at   DateTime @updatedAt
    attributes   Json     @default("{}")

    staffs Staff[] @relation("UserToStaff")
    created_features Feature[] @relation("FeatureCreatedBy")
    created_staffs Staff[] @relation("StaffsCreatedBy")
    created_organizations Organization[] @relation("OrganizationCreatedBy")
    created_projects Project[] @relation("ProjectCreatedBy")

    @@index([email])
    @@index([username])
}

model Organization {
    id          String   @id @default(uuid(7)) @db.Uuid
    name        String
    slug        String   @unique
    description String?
    created_at   DateTime @default(now())
    updated_at   DateTime @updatedAt
    attributes   Json     @default("{}")
    created_by   String?  @db.Uuid
    updated_by   String?  @db.Uuid

    staffs Staff[] @relation("OrganizationToStaff")
    projects Project[] @relation("OrganizationToProject")
    departments Department[] @relation("OrganizationToDepartment")
    policies Policy[] @relation("OrganizationToPolicy")
    roles Role[] @relation("OrganizationToRole")
    
    created_by_user User? @relation("OrganizationCreatedBy", fields: [created_by], references: [id], onDelete: SetNull)

    @@index([slug])
}

model Staff {
    id          String   @id @default(uuid(7)) @db.Uuid
    organization_id String @db.Uuid
    user_id String @db.Uuid
    department_id String? @db.Uuid
    status AccessControlStatus @default(ACTIVE)
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt
    created_by String? @db.Uuid
    updated_by String? @db.Uuid
    context_attributes Json @default("{}")

    members Member[] @relation("MemberToStaff")
    
    user User @relation("UserToStaff", fields: [user_id], references: [id], onDelete: Cascade)
    organization Organization @relation("OrganizationToStaff", fields: [organization_id], references: [id], onDelete: Cascade)
    department Department? @relation("DepartmentToStaff", fields: [department_id], references: [id], onDelete: SetNull)

    created_by_user User? @relation("StaffsCreatedBy", fields: [created_by], references: [id], onDelete: SetNull)

    @@unique([user_id, organization_id])
}

model Project {
    id          String   @id @default(uuid(7)) @db.Uuid
    name        String
    slug        String   @unique
    description String?
    organization_id String @db.Uuid
    department_id String? @db.Uuid
    created_at   DateTime @default(now())
    updated_at   DateTime @updatedAt
    attributes   Json     @default("{}")
    created_by   String?  @db.Uuid
    updated_by   String?  @db.Uuid

    features Feature[] @relation("FeatureToProject")
    members Member[] @relation("MemberToProject")
    
    organization Organization @relation("OrganizationToProject", fields: [organization_id], references: [id], onDelete: Cascade)
    department Department? @relation("DepartmentToProject", fields: [department_id], references: [id], onDelete: SetNull)
    created_by_user User? @relation("ProjectCreatedBy", fields: [created_by], references: [id], onDelete: SetNull)

    @@index([slug])
}

model Member {
    id String @id @default(uuid(7)) @db.Uuid
    staff_id String @db.Uuid
    project_id String @db.Uuid
    status AccessControlStatus @default(ACTIVE)
    context_attributes Json @default("{}")
    
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt
    
    staff Staff @relation("MemberToStaff", fields: [staff_id], references: [id], onDelete: Cascade)
    project Project @relation("MemberToProject", fields: [project_id], references: [id], onDelete: Cascade)
    
    @@unique([staff_id, project_id])
}

model Department {
  id              String   @id @default(uuid(7)) @db.Uuid
  name            String
  slug            String   @unique
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  attributes Json @default("{}") 
  
  organization_id String   @db.Uuid
  
  staffs           Staff[] @relation("DepartmentToStaff")
  projects        Project[] @relation("DepartmentToProject")
  
  organization    Organization @relation("OrganizationToDepartment", fields: [organization_id], references: [id])

  @@unique([organization_id, slug])
}

model Attributes {
  id          String   @id @default(uuid(7)) @db.Uuid
  entity_type String   // e.g., "USER", "PROJECT", "ORGANIZATION"
  key         String   // e.g., "clearance", "department"
  data_type   String   // e.g., "NUMBER", "STRING", "BOOLEAN"
  description String?
  label String?
  category AttributeCategory?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([entity_type, key])
}

model Feature {
    id          String   @id @default(uuid(7)) @db.Uuid
    name        String   
    slug        String   
    description String?
    project_id String @db.Uuid
    status      AccessControlStatus @default(ACTIVE)
    created_at   DateTime @default(now())
    updated_at   DateTime @updatedAt
    attributes   Json     @default("{}")
    created_by   String?  @db.Uuid
    updated_by   String?  @db.Uuid
    
    project Project @relation("FeatureToProject", fields: [project_id], references: [id], onDelete: Cascade)

    created_by_user User? @relation("FeatureCreatedBy", fields: [created_by], references: [id], onDelete: SetNull)

    @@index([slug])
    @@index([status])
    @@unique([project_id, slug])
}

model Subscription {
    id          String   @id @default(uuid(7)) @db.Uuid
    name        String   
    slug        String   
    description String?
    created_at   DateTime @default(now())
    updated_at   DateTime @updatedAt
    
    @@unique([slug])
}

model Clearance {
    id          String   @id @default(uuid(7)) @db.Uuid
    name        String
    level       Int      
    description String?
    created_at   DateTime @default(now())
    updated_at   DateTime @updatedAt
    
    @@unique([level])
}

model Environment {
    id          String   @id @default(uuid(7)) @db.Uuid
    name        String
    slug        String
    description String?
    created_at   DateTime @default(now())
    updated_at   DateTime @updatedAt
    
    @@unique([slug])
}

model Policy {
    id             String   @id @default(uuid(7)) @db.Uuid
    name           String
    description    String?
    effect         Effect   @default(ALLOW)
    action         String   
    resource       String   
    condition      Json     
    organization_id String?  @db.Uuid
    created_at     DateTime @default(now())
    updated_at     DateTime @updatedAt
    
    organization   Organization? @relation("OrganizationToPolicy", fields: [organization_id], references: [id])
    @@index([action, resource])
}

model Role {
    id          String   @id @default(uuid(7)) @db.Uuid
    name        String
    slug        String
    organization_id String @db.Uuid
    description String?
    status      AccessControlStatus @default(ACTIVE)
    created_at   DateTime @default(now())
    updated_at   DateTime @updatedAt
    created_by   String?  @db.Uuid
    updated_by   String?  @db.Uuid
    attributes   Json     @default("{}")

    organization Organization @relation("OrganizationToRole", fields: [organization_id], references: [id], onDelete: Cascade)
    
    @@unique([organization_id, slug])
}

model Notification {
    id            String             @id @default(uuid(7)) @db.Uuid
    recipient     Json               // e.g. { email: "...", telegram_id: "..." }
    channel       NotificationChannel
    content       Json               // e.g. { subject: "...", body: "...", template: "..." }
    status        NotificationStatus @default(PENDING)
    error_message String?
    created_at    DateTime           @default(now())
    updated_at    DateTime           @updatedAt

    @@index([status])
    @@index([channel])
}

enum Effect {
    ALLOW
    DENY
}

enum AccessControlStatus {
    ACTIVE
    INACTIVE
    DELETED
}

enum AttributeCategory {
    RESOURCE
    SUBJECT
    ENVIRONMENT
}

enum NotificationChannel {
    MAIL
    TELEGRAM
    SMS
}

enum NotificationStatus {
    PENDING
    SENT
    FAILED
}